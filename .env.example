# ---- Database (Neon Postgres) ----
# Pooled connection string (runtime)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# Direct/unpooled connection string (migrations)
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ---- Clerk (authentication) ----
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxx"
CLERK_SECRET_KEY="sk_test_xxx"

# Clerk routing (defaults are fine)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/dashboard"

# ---- Seeding ----
# Clerk user id of the demo reviewer (set after creating the demo user)
SEED_OWNER_USER_ID=""
# Display name used for seeded owners/notes (optional)
SEED_OWNER_NAME="Demo Reviewer"
